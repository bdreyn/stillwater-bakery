# =============================================================================
# Stillwater Bakery - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual value.
# NEVER commit your real .env file — it is gitignored.
# For production, set this as a GitHub Actions Secret.
# =============================================================================

# Google Apps Script Web App — deployed URL ending in /exec.
# This is the only backend the site needs: it receives order and inquiry
# form submissions and emails them to the bakery. See apps-script/SETUP.md.
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
